@model AdminAppointmentFilterViewModel
@{
    ViewData["Title"] = "All Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check"></i> All Appointments</h2>
    <form method="get" class="d-flex gap-2">
        <select name="statusFilter" class="form-select" onchange="this.form.submit()">
            <option value="">All Statuses</option>
            @foreach (var opt in Model.StatusOptions)
            {
                <option value="@opt.Value" selected="@(opt.Value == Model.StatusFilter ? "selected" : null)">@opt.Text</option>
            }
        </select>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Specialty</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Appointments)
                {
                    <tr>
                        <td>@a.PatientName</td>
                        <td>@a.DoctorName</td>
                        <td>@a.SpecialtyName</td>
                        <td>@a.AppointmentDate.ToString("g")</td>
                        <td><span class="badge badge-status-@a.Status">@a.Status</span></td>
                        <td>@(string.IsNullOrEmpty(a.Notes) ? "-" : a.Notes)</td>
                    </tr>
                }
                @if (!Model.Appointments.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No appointments found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Admin Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card" style="background-color:#0d6efd;">
            <div class="d-flex justify-content-between">
                <div><h2>@Model.TotalDoctors</h2><span>Doctors</span></div>
                <i class="bi bi-person-badge fs-1"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background-color:#198754;">
            <div class="d-flex justify-content-between">
                <div><h2>@Model.TotalPatients</h2><span>Patients</span></div>
                <i class="bi bi-people fs-1"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background-color:#6f42c1;">
            <div class="d-flex justify-content-between">
                <div><h2>@Model.TotalSpecialties</h2><span>Specialties</span></div>
                <i class="bi bi-clipboard2-pulse fs-1"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background-color:#fd7e14;">
            <div class="d-flex justify-content-between">
                <div><h2>@Model.TotalAppointments</h2><span>Appointments</span></div>
                <i class="bi bi-calendar-check fs-1"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded-3 p-3 text-center bg-white">
            <span class="badge badge-status-Pending mb-2">Pending</span>
            <h4>@Model.PendingAppointments</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 p-3 text-center bg-white">
            <span class="badge badge-status-Confirmed mb-2">Confirmed</span>
            <h4>@Model.ConfirmedAppointments</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 p-3 text-center bg-white">
            <span class="badge badge-status-Completed mb-2">Completed</span>
            <h4>@Model.CompletedAppointments</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 p-3 text-center bg-white">
            <span class="badge badge-status-Cancelled mb-2">Cancelled</span>
            <h4>@Model.CancelledAppointments</h4>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white"><strong>Recent Appointments</strong></div>
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Specialty</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.RecentAppointments.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No appointments yet.</td></tr>
                }
                @foreach (var a in Model.RecentAppointments)
                {
                    <tr>
                        <td>@a.PatientName</td>
                        <td>@a.DoctorName</td>
                        <td>@a.SpecialtyName</td>
                        <td>@a.AppointmentDate.ToString("g")</td>
                        <td><span class="badge badge-status-@a.Status">@a.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

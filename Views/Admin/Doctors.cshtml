@model List<DoctorListItemViewModel>
@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> Manage Doctors</h2>
    <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateDoctor"><i class="bi bi-plus-lg"></i> Add Doctor</a>
</div>

<div class="row g-4">
    @foreach (var d in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm doctor-card">
                <img src='@(string.IsNullOrEmpty(d.ImagePath) ? "/images/doctors/121.png" : $"/images/doctors/{d.ImagePath}")'
                     class="card-img-top" alt="@d.FullName"
                     onerror="this.onerror=null;this.src='https://via.placeholder.com/300x220?text=Doctor';" />
                <div class="card-body">
                    <h5 class="card-title mb-1">@d.FullName</h5>
                    <p class="text-muted mb-1">@d.SpecialtyName</p>
                    <p class="mb-1"><i class="bi bi-envelope"></i> @d.Email</p>
                    <p class="mb-1"><i class="bi bi-telephone"></i> @d.Phone</p>
                    <p class="mb-2"><i class="bi bi-award"></i> @d.ExperienceYears yrs experience</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary flex-fill" asp-action="EditDoctor" asp-route-id="@d.Id">Edit</a>
                        <form asp-action="DeleteDoctor" asp-route-id="@d.Id" method="post" class="flex-fill"
                              onsubmit="return confirm('Delete this doctor?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted text-center mt-4">No doctors found.</p>
}

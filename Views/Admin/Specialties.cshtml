@model List<SpecialtyFormViewModel>
@{
    ViewData["Title"] = "Manage Specialties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard2-pulse"></i> Manage Specialties</h2>
    <a class="btn btn-primary" asp-action="CreateSpecialty"><i class="bi bi-plus-lg"></i> Add Specialty</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Doctors</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Name</td>
                        <td>@s.Description</td>
                        <td><span class="badge bg-secondary">@s.DoctorCount</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="EditSpecialty" asp-route-id="@s.Id">Edit</a>
                            <form asp-action="DeleteSpecialty" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this specialty?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No specialties found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

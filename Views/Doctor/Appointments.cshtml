@model List<AppointmentListItemViewModel>
@{
    ViewData["Title"] = "My Appointments";
}

<h2 class="mb-4"><i class="bi bi-calendar-week"></i> My Appointments</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Patient</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.PatientName</td>
                        <td>@a.AppointmentDate.ToString("g")</td>
                        <td><span class="badge badge-status-@a.Status">@a.Status</span></td>
                        <td>@(string.IsNullOrEmpty(a.Notes) ? "-" : a.Notes)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="PatientDetails" asp-route-id="@a.PatientId">View Patient</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="UpdateStatus" asp-route-id="@a.Id">Update Status</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No appointments assigned yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

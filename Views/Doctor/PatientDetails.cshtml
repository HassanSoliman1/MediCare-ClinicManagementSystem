@model PatientDetailsViewModel
@{
    ViewData["Title"] = "Patient Details";
}

<h2 class="mb-4"><i class="bi bi-person-lines-fill"></i> Patient Details</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">@Model.FullName</h5>
        <p class="mb-1"><i class="bi bi-envelope"></i> @Model.Email</p>
        <p class="mb-0"><i class="bi bi-telephone"></i> @(Model.PhoneNumber ?? "-")</p>
    </div>
</div>

<h5 class="mb-3">Appointment History with You</h5>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.AppointmentHistory)
                {
                    <tr>
                        <td>@a.AppointmentDate.ToString("g")</td>
                        <td><span class="badge badge-status-@a.Status">@a.Status</span></td>
                        <td>@(string.IsNullOrEmpty(a.Notes) ? "-" : a.Notes)</td>
                    </tr>
                }
                @if (!Model.AppointmentHistory.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-3">No history found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a class="btn btn-secondary mt-3" asp-action="Appointments">Back to Appointments</a>

@model List<AppointmentListItemViewModel>
@{
    ViewData["Title"] = "My Appointments";
}

<h2 class="mb-4"><i class="bi bi-clock-history"></i> My Appointment History</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Doctor</th>
                    <th>Specialty</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.DoctorName</td>
                        <td>@a.SpecialtyName</td>
                        <td>@a.AppointmentDate.ToString("g")</td>
                        <td><span class="badge badge-status-@a.Status">@a.Status</span></td>
                        <td>@(string.IsNullOrEmpty(a.Notes) ? "-" : a.Notes)</td>
                        <td class="text-end">
                            @if (a.Status == AppointmentStatus.Pending || a.Status == AppointmentStatus.Confirmed)
                            {
                                <form asp-action="CancelAppointment" asp-route-id="@a.Id" method="post"
                                      onsubmit="return confirm('Cancel this appointment?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">You have no appointments yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a class="btn btn-primary mt-3" asp-action="SearchDoctors">Book Another Appointment</a>

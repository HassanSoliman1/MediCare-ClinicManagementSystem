@model DoctorSearchViewModel
@{
    ViewData["Title"] = "Find a Doctor";
}

<h2 class="mb-4"><i class="bi bi-search"></i> Find a Doctor</h2>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by doctor name..." />
    </div>
    <div class="col-md-4">
        <select name="specialtyId" class="form-select">
            <option value="">All Specialties</option>
            @foreach (var s in Model.Specialties)
            {
                <option value="@s.Value" selected="@(s.Value == Model.SpecialtyId.ToString() ? "selected" : null)">@s.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Search</button>
    </div>
</form>

<div class="row g-4">
    @foreach (var d in Model.Results)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm doctor-card">
                <img src='@(string.IsNullOrEmpty(d.ImagePath) ? "https://via.placeholder.com/300x220?text=Doctor" : $"/images/doctors/{d.ImagePath}")'
                     class="card-img-top" alt="@d.FullName" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-1">@d.FullName</h5>
                    <p class="text-muted mb-1">@d.SpecialtyName</p>
                    <p class="mb-1 small"><i class="bi bi-award"></i> @d.ExperienceYears yrs experience</p>
                    <a class="btn btn-primary mt-auto" asp-action="BookAppointment" asp-route-doctorId="@d.Id">Book Appointment</a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Results.Any())
{
    <p class="text-muted text-center mt-4">No doctors match your search.</p>
}
